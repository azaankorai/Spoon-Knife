# Copy this file to ".env" (which is gitignored) and fill in your real keys.
# NEVER commit your actual .env file - API keys grant control over your account.

# Get these from https://app.alpaca.markets/paper/dashboard/overview
# (paper-trading keys - safe to use while learning, no real money involved)
ALPACA_PAPER_API_KEY=
ALPACA_PAPER_API_SECRET=

# Get these from https://app.alpaca.markets/live/dashboard/overview
# ONLY needed if you set "paper: false" in config.yaml. Leave blank otherwise.
# These keys can place real orders with real money - guard them like a password.
ALPACA_LIVE_API_KEY=
ALPACA_LIVE_API_SECRET=
